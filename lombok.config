# config.stopBubbling = true tells Lombok to stop searching for additional lombok.config files in parent directories,
# ensuring that only the configuration defined within the current project is used. This makes builds consistent across
# all developers and CI environments by preventing inherited or unexpected settings. lombok.addLombokGeneratedAnnotation = true
# instructs Lombok to annotate all generated code (such as getters, setters, constructors, and builders) with @lombok.Generated,
# allowing tools like JaCoCo, SonarQube, SpotBugs, and PMD to recognize and optionally ignore generated code during coverage and
# static analysis. Together, these settings are considered best practices for enterprise Java projects because they provide predictable
# configuration behavior and produce cleaner, more accurate code quality reports.

config.stopBubbling = true
lombok.addLombokGeneratedAnnotation = true