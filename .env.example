# Copy this file to .env and adjust values as needed. .env is gitignored and
# read automatically by docker-compose (for variable substitution, then passed
# into containers as real environment variables - Spring Boot reads those
# natively, no extra library involved). Running the app without Docker (mvn
# spring-boot:run, java -jar) does not read .env automatically; export it into
# your shell first, e.g. `set -a; source .env; set +a`.
#
# These defaults match what was previously hardcoded in docker-compose.yml and
# application.yml - they are dev-only placeholders, not real secrets. Never
# reuse them outside local development (see docs/SECURITY.md, gap #1).
#
# Deliberately NOT here: SPRING_KAFKA_BOOTSTRAP_SERVERS and
# MANAGEMENT_ZIPKIN_TRACING_ENDPOINT. Their correct value depends on whether
# the app runs inside the Docker network (kafka:9092, jaeger:9411) or on the
# host (mvn test, mvn spring-boot:run - which need the embedded/local broker
# instead). If you source this file into your shell before running mvn test,
# those two hostnames would break Kafka client construction with "No
# resolvable bootstrap urls" - keep them out of .env and hardcoded directly
# in docker-compose.yml instead.

# --- PostgreSQL ---
POSTGRES_DB=payment_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- JWT authentication ---
# Must be at least 32 characters for HS256. Set a real random value before
# running anywhere other than local development.
JWT_SECRET=your-super-secret-key-change-in-production-at-least-32-characters-long-for-hs256
# Access token lifetime in milliseconds (1 hour)
JWT_EXPIRATION=3600000

# --- Database startup behavior ---
# true: Flyway drops and recreates the schema on every boot (local dev only).
# Set to false before pointing at any database you don't want wiped; see
# docs/DEPLOYMENT.md for the full production checklist.
DB_RESET_ON_STARTUP=true

# --- Observability ---
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true
# Grafana admin login (http://localhost:3000). Dashboards/datasources are
# auto-provisioned from grafana/ - see docs/DEPLOYMENT.md.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- k6 load testing ---
# k6 does not read .env files natively. Export these into your shell first,
# e.g. `set -a; source .env; set +a`, or pass them with `-e` flags.
BASE_URL=http://localhost:8080
LOAD_TEST_USERNAME=load_test_user
LOAD_TEST_PASSWORD=LoadTest123!
