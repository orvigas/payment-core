{
  "version": 4,
  "folders": [
    {
      "_id": "fld_payment_core",
      "name": "Payment Core API",
      "type": "request_group"
    },
    {
      "_id": "fld_health",
      "name": "Health & System",
      "type": "request_group",
      "parentId": "fld_payment_core"
    },
    {
      "_id": "fld_payments",
      "name": "Payments",
      "type": "request_group",
      "parentId": "fld_payment_core"
    },
    {
      "_id": "fld_create_payment",
      "name": "Create Payment",
      "type": "request_group",
      "parentId": "fld_payments"
    },
    {
      "_id": "fld_retrieve_payment",
      "name": "Retrieve Payment",
      "type": "request_group",
      "parentId": "fld_payments"
    },
    {
      "_id": "fld_payment_operations",
      "name": "Payment Operations",
      "type": "request_group",
      "parentId": "fld_payments"
    }
  ],
  "requests": [
    {
      "_id": "req_health_check",
      "parentId": "fld_health",
      "name": "Health Check",
      "method": "GET",
      "url": "{{ base_url }}/health",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "tests": "pm.test('Status code is 200', function() {\n  pm.response.to.have.status(200);\n});\n\npm.test('Response has status field', function() {\n  var jsonData = pm.response.json();\n  pm.expect(jsonData).to.have.property('status');\n});"
    },
    {
      "_id": "req_app_info",
      "parentId": "fld_health",
      "name": "Application Info",
      "method": "GET",
      "url": "{{ base_url }}/info",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "tests": "pm.test('Status code is 200', function() {\n  pm.response.to.have.status(200);\n});"
    },
    {
      "_id": "req_create_payment_success",
      "parentId": "fld_create_payment",
      "name": "Create Payment - Success",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/payments",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"userId\": \"user_123\",\n  \"amount\": 5000.00,\n  \"currency\": \"MXN\",\n  \"merchant\": \"jersey-mikes\",\n  \"description\": \"Test Payment from Insomnia\"\n}"
      },
      "tests": "pm.test('Status code is 201', function() {\n  pm.response.to.have.status(201);\n});\n\npm.test('Response has paymentId', function() {\n  var jsonData = pm.response.json();\n  pm.expect(jsonData).to.have.property('paymentId');\n  pm.environment.set('payment_id', jsonData.paymentId);\n});\n\npm.test('Payment status is PENDING', function() {\n  var jsonData = pm.response.json();\n  pm.expect(jsonData.status).to.equal('PENDING');\n});\n\npm.test('Amount matches', function() {\n  var jsonData = pm.response.json();\n  pm.expect(jsonData.amount).to.equal(5000);\n});\n\npm.test('Response time is acceptable', function() {\n  pm.expect(pm.response.responseTime).to.be.below(2000);\n});"
    },
    {
      "_id": "req_create_payment_usd",
      "parentId": "fld_create_payment",
      "name": "Create Payment - USD Currency",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/payments",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"userId\": \"user_456\",\n  \"amount\": 2500.50,\n  \"currency\": \"USD\",\n  \"merchant\": \"starbucks\",\n  \"description\": \"USD Payment Test\"\n}"
      },
      "tests": "pm.test('Status code is 201', function() {\n  pm.response.to.have.status(201);\n});\n\npm.test('Currency is USD', function() {\n  var jsonData = pm.response.json();\n  pm.expect(jsonData.currency).to.equal('USD');\n});"
    },
    {
      "_id": "req_create_payment_invalid",
      "parentId": "fld_create_payment",
      "name": "Create Payment - Invalid (Negative Amount)",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/payments",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"userId\": \"user_invalid\",\n  \"amount\": -100.00,\n  \"currency\": \"MXN\",\n  \"merchant\": \"invalid-merchant\",\n  \"description\": \"Invalid payment\"\n}"
      },
      "tests": "pm.test('Status code is 400 (Bad Request)', function() {\n  pm.response.to.have.status(400);\n});\n\npm.test('Error response contains error field', function() {\n  var jsonData = pm.response.json();\n  pm.expect(jsonData).to.have.property('error');\n});"
    },
    {
      "_id": "req_get_payment_success",
      "parentId": "fld_retrieve_payment",
      "name": "Get Payment - Success",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/payments/{{ payment_id }}",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "tests": "pm.test('Status code is 200', function() {\n  pm.response.to.have.status(200);\n});\n\npm.test('Response has payment details', function() {\n  var jsonData = pm.response.json();\n  pm.expect(jsonData).to.have.property('paymentId');\n  pm.expect(jsonData).to.have.property('userId');\n  pm.expect(jsonData).to.have.property('amount');\n  pm.expect(jsonData).to.have.property('status');\n});\n\npm.test('Payment ID matches', function() {\n  var jsonData = pm.response.json();\n  pm.expect(jsonData.paymentId).to.equal(pm.environment.get('payment_id'));\n});"
    },
    {
      "_id": "req_get_payment_not_found",
      "parentId": "fld_retrieve_payment",
      "name": "Get Payment - Not Found",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/payments/invalid-id-12345",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "tests": "pm.test('Status code is 404', function() {\n  pm.response.to.have.status(404);\n});\n\npm.test('Error response received', function() {\n  var jsonData = pm.response.json();\n  pm.expect(jsonData).to.have.property('error');\n});"
    },
    {
      "_id": "req_confirm_payment_success",
      "parentId": "fld_payment_operations",
      "name": "Confirm Payment - Success",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/payments/{{ payment_id }}/confirm",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "tests": "pm.test('Status code is 200', function() {\n  pm.response.to.have.status(200);\n});\n\npm.test('Response has confirmation', function() {\n  var jsonData = pm.response.json();\n  pm.expect(jsonData).to.have.property('paymentId');\n});\n\npm.test('Response time is acceptable', function() {\n  pm.expect(pm.response.responseTime).to.be.below(2000);\n});"
    },
    {
      "_id": "req_confirm_payment_not_found",
      "parentId": "fld_payment_operations",
      "name": "Confirm Payment - Not Found",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/payments/invalid-payment-id/confirm",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "tests": "pm.test('Status code is 404', function() {\n  pm.response.to.have.status(404);\n});"
    },
    {
      "_id": "req_refund_payment_success",
      "parentId": "fld_payment_operations",
      "name": "Refund Payment - Success",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/payments/{{ payment_id }}/refund",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "tests": "pm.test('Status code is 200', function() {\n  pm.response.to.have.status(200);\n});\n\npm.test('Refund response has details', function() {\n  var jsonData = pm.response.json();\n  pm.expect(jsonData).to.have.property('paymentId');\n});"
    },
    {
      "_id": "req_refund_payment_not_found",
      "parentId": "fld_payment_operations",
      "name": "Refund Payment - Not Found",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/payments/invalid-payment-id/refund",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "tests": "pm.test('Status code is 404', function() {\n  pm.response.to.have.status(404);\n});"
    }
  ],
